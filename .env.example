# =============================================================================
# Quantitative Trading Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Local dev:   cp .env.example .env && edit .env
# Railway:     Set these in the Railway dashboard (Variables tab)
# Vercel:      Set VITE_* vars in the Vercel dashboard (Environment Variables)
# =============================================================================

# -----------------------------------------------------------------------------
# Security (REQUIRED in production)
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# JWT token lifetime in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Database
# Dev:        leave empty — defaults to SQLite at ./quant_engine.db
# Production: postgresql://user:password@host:5432/dbname
#             (Railway Postgres provides this automatically)
# -----------------------------------------------------------------------------
DATABASE_URL=

# PostgreSQL connection pool (ignored for SQLite)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# Redis (optional but strongly recommended for production)
# Enables: Redis caching, Celery task queue, rate limiting with shared state
# Railway Redis provides REDIS_URL automatically when you add the plugin.
# -----------------------------------------------------------------------------
REDIS_URL=

# Celery broker (defaults to REDIS_URL if not set separately)
CELERY_BROKER_URL=

# -----------------------------------------------------------------------------
# CORS (Frontend origin)
# Dev:        leave empty or set to *
# Production: https://your-app.vercel.app
#             Multiple origins: https://app.vercel.app,https://custom-domain.com
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# -----------------------------------------------------------------------------
# External API Keys
# -----------------------------------------------------------------------------

# Federal Reserve Economic Data (FRED)
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Sentry error tracking (optional but strongly recommended)
# Get DSN at: https://sentry.io
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Storage Directories (optional — defaults to ./runs/*)
# Set these to absolute paths on your server, or an S3-mounted volume.
# -----------------------------------------------------------------------------
ARTIFACTS_DIR=
DATA_DIR=
OPTIONS_DIR=
SECTORS_DIR=

# -----------------------------------------------------------------------------
# Frontend (Vite) — prefix with VITE_ to expose to browser
# Set in Vercel dashboard under Environment Variables
# -----------------------------------------------------------------------------

# Backend API base URL (only needed if not using Vercel rewrites)
# VITE_API_URL=https://quantitative-trading-engine-production.up.railway.app
